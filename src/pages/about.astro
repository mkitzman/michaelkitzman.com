---
import { Image } from "astro:assets";
import avatar from "@/assets/avatar.png";
import PageLayout from "@/layouts/Base.astro";
import DLList from "@/components/DLList.astro";

const meta = {
	description: "About Michael Kitzman",
	title: "About",
};

const mikeTech: { desc: string; title: string }[] = [
	{
		desc: "Building fast, scalable web applications across modern JavaScript and Vue ecosystems.",
		title: "JavaScript",
	},
	{
		desc: "Experience with CSS in all forms: SASS, CSS-in-JS, utility-first, and Tailwind.",
		title: "CSS",
	},
	{
		desc: "Well-versed in semantic HTML for accessible, structured content.",
		title: "HTML",
	},
	{
		desc: "Designing and developing inclusive products that work for everyone.",
		title: "Accessibility",
	},
	{
		desc: "Led design system teams and built design systems from scratch.",
		title: "Design Systems",
	},
	{
		desc: "AI-assisted development with Claude and Claude Code, prompt engineering, and LLM integration.",
		title: "AI Tooling",
	},
	{
		desc: "Vitest, Jest, React Testing Library, Chrome DevTools, and A11Y tools.",
		title: "Testing",
	},
	{
		desc: "Webpack, Babel, ESLint, GitHub, GitHub Actions, DataDog, Sentry, and CI/CD.",
		title: "DivOps",
	},
	{
		desc: "Responsive web design, mobile-first, PageSpeed Insights, and Lighthouse.",
		title: "Web Apps",
	},
];
---

<style>
	.avatar {
		border-radius: 48% 52% 38% 62%/27% 28% 72% 73%;
		width: 200px;
	}
	.textHightlight {
		padding: 0 6px;
		display: inline-flex;
		font-weight: bold;
		border-radius: 4px;
	}

	.broncos {
		background-color: #112d50;
		color: #e37838;
	}
	.lakers {
		background-color: #552583;
		color: #fdb927;
	}
	.chelsea {
		background-color: #034694;
		color: #ffffff;
	}
</style>

<PageLayout meta={meta}>
	<div class="space-y-6">
		<h1 class="title">About</h1>
		<div class="float-right">
			<Image alt="Profile Photo" fetchpriority="high" loading="eager" class="avatar" src={avatar} />
		</div>
		<p>
			I'm a product-minded engineer with extensive experience building web products used by billions
			of people. I work at the intersection of UI engineering and generative AI, pairing deep
			frontend craft (JavaScript, CSS, accessibility, design systems) with AI tooling and agentic
			workflows to ship fast, user-first products. I care less about which layer I'm in and more about
			turning complex problems into seamless experiences.
		</p>

		<p>
			I build with AI tooling and agentic workflows (Claude and Claude Code), Vue, HTML5, CSS3,
			JavaScript (ES6+), Accessibility, and modern build systems. AI-assisted development is core to
			how I ship. I lean on agentic workflows to move fast and raise the bar on quality. I've also
			built two design systems from the ground up: I led the Teachable Design System Uni (docs in
			Storybook) and worked on Medallia Alchemy (docs in Gatsby).
		</p>
		<section class="mt-16">
			<h2 class="title mb-4 text-xl">Skillset</h2>
			<dl class="space-y-4">
				{
					mikeTech.map(({ desc, title }) => (
						<div class="flex flex-col gap-2 sm:flex-row">
							<dt>
								<span class="flex">
									<strong>{title}</strong>:
								</span>
							</dt>
							<dd>{desc}</dd>
						</div>
					))
				}
			</dl>
		</section>
		<section class="mt-16">
			<h2 class="text-l title mb-4">Work</h2>
			<ul>
				<li class="mb-6">
					<h3>
						<a
							class="cactus-link text-xl font-semibold"
							href="https://fantasypros.com"
							rel="noreferrer"
							target="_blank"
						>
							FantasyPros: Fantasy Sports research website
						</a>
					</h3>
					<h4 class="font-semibold">Senior Frontend Engineer</h4>
					<p>
						Product-minded engineer bridging advanced UI engineering and generative AI.
						Architecting the high-performance interfaces that help millions of users dominate their
						leagues.
					</p>
					<ul class="mt-3 list-disc space-y-2 ps-5">
						<li>
							<strong>AI-Native Product Delivery:</strong> Shipping intuitive, data-dense features
							powered by Vue.js and intelligent LLM workflows (including Claude).
						</li>
						<li>
							<strong>Modern CSS &amp; Accessibility:</strong> Crafting responsive, fluid
							scrollytelling experiences and resilient design systems optimized for strict WCAG
							compliance and seamless semantic layouts.
						</li>
						<li>
							<strong>Product-Driven Engineering:</strong> Collaborating across product and design to
							rapidly turn complex sports data into fast, accessible, user-first tools.
						</li>
					</ul>
				</li>
				<li class="mb-6">
					<h3>
						<a
							class="cactus-link text-xl font-semibold"
							href="https://teachable.com"
							rel="noreferrer"
							target="_blank"
						>
							Teachable: Creator Economy platform post-acquisition.
						</a>
					</h3>
					<h4 class="font-semibold">
						Senior Frontend Engineer, Engineering Enablement & Design System Lead
					</h4>
					<p>
						Collaborated on a team focused on empowering teams to develop more efficiently, improve
						code quality, and accelerate product delivery across the entire company. Led the
						development and maintenance of a unified design system, driving consistency,
						scalability, and accessibility across UI components.
					</p>
				</li>
				<li class="mb-6">
					<h3>
						<a
							class="cactus-link text-xl font-bold"
							href="https://www.medallia.com"
							rel="noreferrer"
							target="_blank"
						>
							Medallia: Experience Management Platform post-IPO.
						</a>
					</h3>
					<h4 class="font-semibold">Senior Frontend Engineer, Design System</h4>
					<p>
						Drove consistency, scalability, and design excellence across Medallia's global
						ecosystem, serving renowned clients such as Apple and Bank of America, and setting the
						standard for exceptional user experiences.
					</p>
				</li>
				<li class="mb-6">
					<h3>
						<a
							class="cactus-link text-xl font-bold"
							href="https://www.oracle.com/"
							rel="noreferrer"
							target="_blank"
						>
							Oracle via AddThis Acquisition: Oracle Marketing Cloud
						</a>
					</h3>
					<h4 class="font-semibold">Principal Frontend Engineer</h4>
					<p>
						Played a critical role in a high-performing team delivering a product reaching 1.9
						billion unique visitors monthly across 15 million domains, with 280 billion
						interactions, and available in 70 languages. Spearheaded the development of the admin
						application, empowering users to customize marketing promotions.
					</p>
				</li>
				<li>
					<h3>
						<a
							class="cactus-link text-xl font-bold"
							href="https://sports.yahoo.com/fantasy"
							rel="noreferrer"
							target="_blank"
						>
							Yahoo! Sports: Fantasy Sports website
						</a>
					</h3>
					<h4 class="font-semibold">Principal Frontend Engineer</h4>
					<p>
						Collaborated on the development of the #1 Fantasy Sports website, attracting tens of
						millions of views monthly, delivering user-focused products adhering to web standards
						and leveraging cutting-edge techniques.
					</p>
				</li>
			</ul>
			<h3 class="text-l mt-8">
				<a
					class="cactus-link"
					href="https://www.linkedin.com/in/michaelkitzman/"
					rel="noreferrer"
					target="_blank"
				>
					Full Resume on LinkedIn
				</a>
			</h3>
		</section>
	</div>
</PageLayout>
